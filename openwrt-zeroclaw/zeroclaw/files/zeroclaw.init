#!/bin/sh /etc/rc.common

START=99
STOP=10

USE_PROCD=1
PROG=/usr/bin/zeroclaw

start_service() {
    config_load zeroclaw
    config_get enabled main enabled 0
    config_get port main port 8080

    [ "$enabled" -eq 1 ] || return 0

    procd_open_instance
    procd_set_param command $PROG --port $port
    procd_set_param respawn
    procd_close_instance
}

stop_service() {
    killall zeroclaw 2>/dev/null
}

reload_service() {
    stop
    start
}
